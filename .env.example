# Required by standalone Docker mode. Use a unique random value (32+ bytes).
BABY_MONITOR_ADMIN_TOKEN=

# Host port for the standalone web interface.
BABY_MONITOR_BIND_ADDRESS=127.0.0.1
BABY_MONITOR_PORT=8099

# Set to 1 when the browser reaches this app exclusively through an HTTPS
# reverse proxy. This marks the standalone session cookie Secure.
BABY_MONITOR_COOKIE_SECURE=0
